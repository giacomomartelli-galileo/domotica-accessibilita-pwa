{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Anteprima PWA",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Ready in|Local:\\s+http"
        }
      },
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}
