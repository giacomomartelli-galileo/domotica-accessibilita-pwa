{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Anteprima PWA (porta 3000)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://[^\\s]+)",
        "uriFormat": "%s/preview",
        "action": "openExternally"
      }
    }
  ]
}
